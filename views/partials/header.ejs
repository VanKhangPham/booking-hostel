<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hệ thống đặt phòng khách sạn</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Đặt phòng khách sạn</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Trang chủ</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/hotels">Khách sạn</a>
          </li>
          <% if (currentUser) { %>
            <li class="nav-item">
              <a class="nav-link" href="/bookings">Phòng của tôi</a>
            </li>
            <% if (currentUser.isAdmin) { %>
              <li class="nav-item">
                <a class="nav-link" href="/hotels/new">Thêm khách sạn</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/bookings/admin">Tất cả phòng đã đặt</a>
              </li>
            <% } %>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <% if (currentUser) { %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/profile">Hồ sơ</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/auth/logout">Đăng xuất</a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/login">Đăng nhập</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/auth/register">Đăng ký</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
  
  <div class="container mt-4">
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">
        <%= success %>
      </div>
    <% } %>
    
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger">
        <%= error %>
      </div>
    <% } %>
    
    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(error) { %>
          <p><%= error.msg %></p>
        <% }); %>
      </div>
    <% } %>