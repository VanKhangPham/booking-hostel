<%- include('../partials/header') %>

<div class="row">
  <div class="col-md-6 mx-auto">
    <div class="card">
      <div class="card-header">
        <h3>Profile</h3>
      </div>
      <div class="card-body">
        <p><strong>Name:</strong> <%= currentUser.name %></p>
        <p><strong>Email:</strong> <%= currentUser.email %></p>
        <p><strong>Account Type:</strong> <%= currentUser.isAdmin ? 'Administrator' : 'User' %></p>
        <p><strong>Member Since:</strong> <%= currentUser.createdAt.toLocaleDateString() %></p>
        <a href="/bookings" class="btn btn-primary">Xem phòng đã đặt</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>