<%- include('../partials/header') %>

<h1 class="mb-4">Chỉnh sửa</h1>

<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <div class="card-body">
        <form action="/hotels/<%= hotel._id %>?_method=PUT" method="POST">
          <div class="mb-3">
            <label for="name" class="form-label">Tên Khách sạn</label>
            <input type="text" class="form-control" id="name" name="name" value="<%= hotel.name %>" required>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label">Mô tả</label>
            <textarea class="form-control" id="description" name="description" rows="5" required><%= hotel.description %></textarea>
          </div>

          <div class="mb-3">
            <label for="address" class="form-label">Địa chỉ</label>
            <input type="text" class="form-control" id="address" name="address" value="<%= hotel.address %>" required>
          </div>

          <div class="mb-3">
            <label for="city" class="form-label">Thành phố</label>
            <input type="text" class="form-control" id="city" name="city" value="<%= hotel.city %>" required>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label for="price" class="form-label">Giá mỗi đêm (VND)</label>
              <input type="number" class="form-control" id="price" name="price" value="<%= hotel.price %>" min="1" required>
            </div>
            <div class="col-md-6">
              <label for="rooms" class="form-label">Số phòng</label>
              <input type="number" class="form-control" id="rooms" name="rooms" value="<%= hotel.rooms %>" min="1" required>
            </div>
          </div>

          <div class="mb-3">
            <label for="amenities" class="form-label">Tiện nghi (cách nhau bằng dấu phẩy)</label>
            <input type="text" class="form-control" id="amenities" name="amenities" value="<%= hotel.amenities.join(', ') %>">
          </div>

          <button type="submit" class="btn btn-primary">Cập nhật</button>
          <a href="/hotels/<%= hotel._id %>" class="btn btn-secondary">Thoát</a>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>