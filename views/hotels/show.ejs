<%- include('../partials/header') %>

<div class="row">
  <div class="col-md-8">
    <h1><%= hotel.name %></h1>
    <p class="lead"><%= hotel.address %>, <%= hotel.city %></p>

    <div class="mb-4">
      <img src="<%= hotel.images[0] %>" class="img-fluid rounded" alt="<%= hotel.name %>" onerror="this.onerror=null;this.src='/img/default-hotel.jpg';">
    </div>

    <div class="mb-4">
      <h3>Description</h3>
      <p><%= hotel.description %></p>
    </div>

    <div class="mb-4">
      <h3>Amenities</h3>
      <ul class="list-group">
        <% hotel.amenities.forEach(amenity => { %>
          <li class="list-group-item"><%= amenity %></li>
        <% }); %>
      </ul>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card mb-4">
      <div class="card-header">
        <h3>VND<%= hotel.price %> <small class="text-muted">mỗi đêm</small></h3>
      </div>
      <div class="card-body">
        <p>Available Rooms: <%= hotel.rooms %></p>
        <% if (currentUser) { %>
          <a href="/bookings/new/<%= hotel._id %>" class="btn btn-success btn-lg w-100">Đặt ngay</a>
        <% } else { %>
          <a href="/auth/login" class="btn btn-primary btn-lg w-100">Đăng nhập để đặt phòng</a>
        <% } %>
      </div>
    </div>

    <% if (currentUser && currentUser.isAdmin) { %>
      <div class="card">
        <div class="card-header">Admin Actions</div>
        <div class="card-body">
          <a href="/hotels/<%= hotel._id %>/edit" class="btn btn-warning mb-2 w-100">Sửa khách sạn</a>
          <form action="/hotels/<%= hotel._id %>?_method=DELETE" method="POST">
            <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Are you sure you want to delete this hotel?')">Xóa khách sạn</button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>